{
  "@context": [
    "http://www.w3.org/ns/odrl.jsonld",
    {
      "ex": "https://hospital-example.org/",
      "dbo": "http://dbpedia.org/ontology/",
      "vcard": "http://www.w3.org/2006/vcard/ns#",
      "ex:subjectDepartmentId": {
        "@type": "@id"
      },
      "ex:resourceDepartmentId": {
        "@type": "@id"
      }
    }
  ],
  "@type": "odrl:Set",
  "uid": "ex:policy/P06",
  "permission": [
    {
      "@type": "odrl:Permission",
      "assigner": {
        "@type": [
          "odrl:Party",
          "dbo:Hospital"
        ],
        "uid": "ex:authority",
        "vcard:fn": "Hospital"
      },
      "assignee": {
        "@type": [
          "odrl:PartyCollection",
          "vcard:Group",
          "dbo:Physician"
        ],
        "uid": "ex:groups/dept-heads",
        "vcard:fn": "Department Heads"
      },
      "action": "odrl:read",
      "target": "ex:systems/db/tables/Historial_Clinico",
      "constraint": [
        {
          "@type": "odrl:Constraint",
          "leftOperand": "ex:subjectDepartmentId",
          "operator": "odrl:eq",
          "rightOperand": "ex:resourceDepartmentId"
        }
      ]
    }
  ]
}