{
  "@context": [
    "http://www.w3.org/ns/odrl.jsonld",
    {
      "ex": "https://hospital-example.org/",
      "dbo": "http://dbpedia.org/ontology/",
      "vcard": "http://www.w3.org/2006/vcard/ns#"
    }
  ],
  "@type": "odrl:Set",
  "uid": "ex:policy/P02",
  "permission": [
    {
      "@type": "odrl:Permission",
      "assigner": {
        "@type": [
          "odrl:Party",
          "dbo:Hospital"
        ],
        "uid": "ex:authority",
        "vcard:fn": "Hospital"
      },
      "assignee": {
        "@type": [
          "odrl:PartyCollection",
          "vcard:Group"
        ],
        "uid": "ex:groups/admin",
        "vcard:fn": "System Admins"
      },
      "action": [
        "odrl:modify",
        "odrl:delete"
      ],
      "target": "ex:systems/db/tables/Empleados"
    }
  ]
}