{
"@context": [
"http://www.w3.org/ns/odrl.jsonld",
{
"ex": "https://hospital-example.org/",
"dbo": "http://dbpedia.org/ontology/",
"vcard": "http://www.w3.org/2006/vcard/ns#",
"ex:currentTime": { "@type": "xsd:dateTime" },
27
"ex:subjectShiftStart": { "@type": "xsd:time" },
"ex:subjectShiftEnd": { "@type": "xsd:time" }
}
],
"@type": "odrl:Set",
"uid": "ex:policy/P10",
"permission": [{
"@type": "odrl:Permission",
"assigner": {
"@type": ["odrl:Party", "dbo:Hospital"],
"uid": "ex:authority",
"vcard:fn": "Hospital"
},
"assignee": {
"@type": ["odrl:PartyCollection", "vcard:Group", "dbo:Nurse"],
"uid": "ex:groups/nursing-staff"
},
"action": ["odrl:read", "odrl:modify"],
"target": "ex:systems/db/tables/Medicacion",
"constraint": [{
"@type": "odrl:LogicalConstraint",
"and": [
{
"@type": "odrl:Constraint",
"leftOperand": "ex:currentTime",
"operator": "odrl:gteq",
"rightOperand": "ex:subjectShiftStart"
},
{
"@type": "odrl:Constraint",
"leftOperand": "ex:currentTime",
"operator": "odrl:lteq",
"rightOperand": "ex:subjectShiftEnd"
}
]
}]
}]
}
