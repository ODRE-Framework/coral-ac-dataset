}
],
"@type": "odrl:Set",
"uid": "ex:policy/P05",
"permission": [{
"@type": "odrl:Permission",
"assigner": {
"@type": ["odrl:Party", "dbo:Hospital"],
14
"uid": "ex:authority",
"vcard:fn": "Hospital"
},
"assignee": {
"@type": ["odrl:PartyCollection", "vcard:Group", "dbo:Physician"],
"uid": "ex:groups/medical-staff"
},
"action": "odrl:modify",
"target": "ex:systems/db/tables/Historial_Clinico",
"constraint": [{
